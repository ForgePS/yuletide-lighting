{
  "name": "yuletide-lighting",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "deploy:firebase": "node scripts/deploy-firebase.mjs",
    "deploy:hosting": "node scripts/deploy-firebase.mjs --hosting-only",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "shift-payments-2025": "node scripts/shift-2026-payments-to-2025.mjs",
    "shift-payments-2025:apply": "node scripts/shift-2026-payments-to-2025.mjs --apply"
  },
  "devDependencies": {
    "firebase-tools": "^13.29.1",
    "next": "^15.1.3",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "20"
  },
  "overrides": {
    "react-native": "0.81.5",
    "expo-notifications": "~0.32.17",
    "expo-image-picker": "~17.0.11",
    "expo-location": "~19.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-constants": "~18.0.13",
    "@clcrm/web": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    },
    "@clcrm/mobile": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "react-native": "0.81.5",
      "expo-notifications": "~0.32.17",
      "expo-image-picker": "~17.0.11",
      "expo-location": "~19.0.8",
      "expo-secure-store": "~15.0.8",
      "expo-status-bar": "~3.0.9",
      "expo-constants": "~18.0.13"
    }
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.62.2"
  }
}

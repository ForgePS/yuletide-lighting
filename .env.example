# Firebase — Yuletide Lighting (yuletide-lighting)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyD9jk7wARDfxpaYxigLKTJ13gK7eCBhCEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=yuletide-lighting.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=yuletide-lighting
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=yuletide-lighting.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=928287362183
NEXT_PUBLIC_FIREBASE_APP_ID=1:928287362183:web:e0cca4d6e2f6d89cc3bc22

# Firebase Admin (server) — paste service account JSON as single line for local dev.
# On deploy, this is copied to CLCRM_FIREBASE_ADMIN_KEY (Firebase strips FIREBASE_* server vars).
FIREBASE_SERVICE_ACCOUNT_KEY=
# Optional explicit deploy key (same JSON); overrides FIREBASE_SERVICE_ACCOUNT_KEY when set.
CLCRM_FIREBASE_ADMIN_KEY=

# Legacy Postgres (optional — Firestore is primary)
DATABASE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# Resend Email
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_TOKEN=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# TinaCMS — https://app.tina.io (Path to Tina config in monorepo: apps/web)
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
NEXT_PUBLIC_TINA_BRANCH=main

# Creator console — comma-separated platform operator emails and/or Firebase UIDs
# Comma-separated emails with Creator Console (multi-tenant admin) access.
PLATFORM_CREATOR_EMAILS=
PLATFORM_CREATOR_UIDS=
